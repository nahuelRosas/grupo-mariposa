NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://library:replace-me-with-strong-password@postgres:5432/db_catalog?schema=public

LOAN_SERVICE_GRPC=loans:50051
LOAN_SERVICE_TIMEOUT_MS=3000

LOAN_SERVICE_URL=http://loans:8080
LOAN_TRANSPORT=http

GRPC_PROTO_PATH=../proto/library.proto

JWT_SECRET=replace-me-with-32-bytes-minimum-secret
JWT_EXPIRES_IN=1h

BCRYPT_ROUNDS=12

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
LOGIN_THROTTLE_LIMIT=5
